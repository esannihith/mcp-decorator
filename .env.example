# Upstream vendor MCP server (korotovsky/slack-mcp-server by default).
# Include the transport path: /sse for SSE, /mcp for streamable HTTP.
VENDOR_SLACK_MCP_URL=http://127.0.0.1:13080/sse

# Only if the vendor server was started with SLACK_MCP_API_KEY.
# VENDOR_API_KEY=

# Where the wrapper listens.
WRAPPER_HOST=127.0.0.1
WRAPPER_PORT=8080
